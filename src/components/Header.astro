---
interface Props {
  onGenerateUrl?: () => void;
}

const { onGenerateUrl } = Astro.props;
---

<header class="bg-gray-900 border-b border-slate-800 px-6 py-4 flex justify-between items-center">
  <h1 class="text-xl font-bold text-green-400 font-mono tracking-tight">
    URL2Web<span class="text-sm font-normal lowercase">.ronnakrit.net</span>
  </h1>
  {onGenerateUrl && (
    <button
      id="generate-url-btn"
      class="bg-gray-800 text-green-400 border border-green-600 rounded hover:bg-gray-700 hover:border-green-400 transition-colors duration-200 font-mono px-4 py-1.5 text-sm"
    >
      Generate URL2Web
    </button>
  )}
</header>
