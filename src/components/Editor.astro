---
---

<div id="editor-mode" class="h-screen flex flex-col">
  <!-- Header -->
  <header class="bg-gray-900 border-b border-slate-800 px-6 py-4 flex justify-between items-center">
    <h1 class="text-xl font-bold text-green-400 font-mono tracking-tight">
      URL2Web<span class="text-sm font-normal lowercase">.ronnakrit.net</span>
    </h1>
    <button
      id="generate-url-btn"
      class="bg-gray-800 text-green-400 border border-green-600 rounded hover:bg-gray-700 hover:border-green-400 transition-colors duration-200 font-mono px-4 py-1.5 text-sm"
    >
      Generate URL2Web
    </button>
  </header>

  <!-- Full-Width Formatting Toolbar -->
  <div class="bg-gray-800 border-b border-slate-700 px-4 py-2 flex justify-between items-center">
    <div class="flex gap-2 flex-wrap">
      <button data-format="bold" class="format-btn bg-slate-700 hover:bg-slate-600 text-slate-200 px-3 py-1 rounded text-sm font-medium transition-colors" title="Bold (Ctrl+B)">**B**</button>
      <button data-format="italic" class="format-btn bg-slate-700 hover:bg-slate-600 text-slate-200 px-3 py-1 rounded text-sm italic transition-colors" title="Italic (Ctrl+I)">*I*</button>
      <button data-format="h1" class="format-btn bg-slate-700 hover:bg-slate-600 text-slate-200 px-3 py-1 rounded text-sm font-bold transition-colors" title="Heading 1">H1</button>
      <button data-format="h2" class="format-btn bg-slate-700 hover:bg-slate-600 text-slate-200 px-3 py-1 rounded text-sm font-semibold transition-colors" title="Heading 2">H2</button>
      <button data-format="link" class="format-btn bg-slate-700 hover:bg-slate-600 text-slate-200 px-3 py-1 rounded text-sm transition-colors" title="Link">🔗</button>
      <button data-format="list" class="format-btn bg-slate-700 hover:bg-slate-600 text-slate-200 px-3 py-1 rounded text-sm transition-colors" title="Bullet List">• List</button>
    </div>
    <div class="flex items-center gap-3">
      <label class="text-sm text-slate-400">Background Theme</label>
      <select id="theme-selector" class="bg-slate-950 text-slate-100 px-3 py-2 rounded-lg border border-slate-700 text-sm focus:outline-none focus:border-blue-500">
        <option value="bg-slate-950" selected>Default Dark</option>
        <option value="bg-gray-900">Deep Gray</option>
        <option value="bg-blue-950">Midnight Blue</option>
      </select>
    </div>
  </div>

  <!-- Split View -->
  <div class="flex-1 flex overflow-hidden">
    <!-- Left Pane - Editor -->
    <div class="w-1/2 flex flex-col border-r border-slate-800">
      <textarea
        id="markdown-editor"
        class="flex-1 bg-slate-950 text-slate-100 p-6 font-mono text-sm resize-none focus:outline-none"
        placeholder="Start writing your Markdown here..."
      ></textarea>
    </div>

    <!-- Right Pane - Preview -->
    <div id="preview-pane" class="w-1/2 bg-slate-950 overflow-auto">
      <div class="max-w-4xl mx-auto px-6 py-12">
        <div id="markdown-preview" class="prose prose-invert max-w-full break-words"></div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="bg-slate-900 border-t border-slate-800 px-6 py-4 flex justify-start items-center">
    <span class="text-sm text-slate-400" id="char-count">0 characters</span>
  </div>

  <!-- URL Generation Modal -->
  <div id="url-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 max-w-2xl w-full mx-4 shadow-2xl">
      <h2 class="text-xl font-semibold text-slate-100 mb-4">Your Shareable URL</h2>
      <div class="flex gap-2 mb-4">
        <input
          type="text"
          id="generated-url"
          class="flex-1 bg-slate-950 text-slate-100 px-4 py-2 rounded-lg border border-slate-700 font-mono text-sm"
          readonly
        />
        <button
          id="copy-url-btn"
          class="bg-gray-800 text-gray-300 border border-gray-700 hover:bg-gray-700 hover:text-white transition-colors rounded px-3 py-1.5 text-sm font-mono"
        >
          Copy
        </button>
      </div>
      <p class="text-sm text-slate-400 mb-4">
        This URL contains your compressed Markdown content. Share it with anyone to let them view your document.
      </p>
      <div class="flex justify-end gap-3">
        <button
          id="open-url-btn"
          class="bg-green-600 text-white hover:bg-green-500 font-mono transition-colors rounded px-4 py-2 text-sm"
        >
          Open URL
        </button>
        <button
          id="close-modal-btn"
          class="bg-gray-800 text-gray-300 border border-gray-700 hover:bg-gray-700 hover:text-white transition-colors rounded px-3 py-1.5 text-sm font-mono"
        >
          Close
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  import { compress } from '../utils/compression';
  import { parse } from '../utils/markdown';

  const markdownEditor = document.getElementById('markdown-editor') as HTMLTextAreaElement | null;
  const markdownPreview = document.getElementById('markdown-preview') as HTMLElement | null;
  const charCount = document.getElementById('char-count') as HTMLElement | null;
  const generateUrlBtn = document.getElementById('generate-url-btn') as HTMLButtonElement | null;
  const themeSelector = document.getElementById('theme-selector') as HTMLSelectElement | null;
  const previewPane = document.getElementById('preview-pane') as HTMLElement | null;
  const formatButtons = document.querySelectorAll('.format-btn');
  const urlModal = document.getElementById('url-modal') as HTMLElement | null;
  const generatedUrl = document.getElementById('generated-url') as HTMLInputElement | null;
  const copyUrlBtn = document.getElementById('copy-url-btn') as HTMLButtonElement | null;
  const openUrlBtn = document.getElementById('open-url-btn') as HTMLButtonElement | null;
  const closeModalBtn = document.getElementById('close-modal-btn') as HTMLButtonElement | null;

  function debounce<T extends (...args: unknown[]) => void>(func: T, wait: number): (...args: Parameters<T>) => void {
    let timeout: number | undefined;
    return function executedFunction(this: unknown, ...args: Parameters<T>) {
      const later = () => {
        clearTimeout(timeout);
        func.apply(this, args);
      };
      clearTimeout(timeout);
      timeout = window.setTimeout(later, wait);
    };
  }

  function updatePreview() {
    if (!markdownEditor || !markdownPreview || !charCount) return;
    const markdown = markdownEditor.value;
    charCount.textContent = `${markdown.length} characters`;
    markdownPreview.innerHTML = parse(markdown);
  }

  function updatePreviewTheme() {
    if (!themeSelector || !previewPane) return;
    const theme = themeSelector.value;
    previewPane.classList.remove('bg-slate-950', 'bg-gray-900', 'bg-blue-950');
    previewPane.classList.add(theme);
    if (typeof window !== 'undefined') {
      localStorage.setItem('url2web_draft_theme', theme);
    }
  }

  function saveDraft() {
    if (typeof window !== 'undefined' && markdownEditor) {
      localStorage.setItem('url2web_draft_text', markdownEditor.value);
    }
  }

  function restoreDraft() {
    if (typeof window !== 'undefined') {
      const savedText = localStorage.getItem('url2web_draft_text');
      const savedTheme = localStorage.getItem('url2web_draft_theme');

      if (savedText && markdownEditor) {
        markdownEditor.value = savedText;
        updatePreview();
      }

      if (savedTheme && themeSelector) {
        themeSelector.value = savedTheme;
        updatePreviewTheme();
      }
    }
  }

  function insertMarkdown(format: string) {
    if (!markdownEditor) return;
    const start = markdownEditor.selectionStart;
    const end = markdownEditor.selectionEnd;
    const selectedText = markdownEditor.value.substring(start, end);

    let before = '';
    let after = '';
    let placeholder = '';

    switch (format) {
      case 'bold':
        before = '**';
        after = '**';
        placeholder = 'bold text';
        break;
      case 'italic':
        before = '*';
        after = '*';
        placeholder = 'italic text';
        break;
      case 'h1':
        before = '# ';
        after = '';
        placeholder = 'Heading 1';
        break;
      case 'h2':
        before = '## ';
        after = '';
        placeholder = 'Heading 2';
        break;
      case 'link':
        before = '[';
        after = '](url)';
        placeholder = 'link text';
        break;
      case 'list':
        before = '- ';
        after = '';
        placeholder = 'list item';
        break;
    }

    const newText = markdownEditor.value.substring(0, start) + before + (selectedText || placeholder) + after + markdownEditor.value.substring(end);
    markdownEditor.value = newText;

    const newCursorPos = start + before.length + (selectedText || placeholder).length + after.length;
    markdownEditor.setSelectionRange(newCursorPos, newCursorPos);
    markdownEditor.focus();

    updatePreview();
  }

  const debouncedUpdatePreview = debounce(updatePreview, 300);

  function generateUrl() {
    if (typeof window === 'undefined' || !markdownEditor || !themeSelector || !urlModal || !generatedUrl) return;
    
    const markdown = markdownEditor.value;
    
    if (!markdown.trim()) {
      alert('Please enter some Markdown content first.');
      return;
    }
    
    const theme = themeSelector.value;
    const payload = JSON.stringify({ theme, markdown });
    
    try {
      const compressed = compress(payload);
      
      let url;
      if (window.location.origin === 'null' || window.location.origin.includes('file://')) {
        url = window.location.href.split('#')[0] + '#' + compressed;
      } else {
        url = window.location.origin + window.location.pathname + '#' + compressed;
      }
      
      generatedUrl.value = url;
      urlModal.classList.remove('hidden');
    } catch (error) {
      console.error('Compression error:', error);
      alert('Failed to compress content. Please try again.');
    }
  }

  function closeModal() {
    if (urlModal) {
      urlModal.classList.add('hidden');
    }
  }

  async function copyUrl() {
    if (!generatedUrl) return;
    try {
      await navigator.clipboard.writeText(generatedUrl.value);
      if (copyUrlBtn) {
        copyUrlBtn.textContent = 'Copied!';
        setTimeout(() => {
          if (copyUrlBtn) copyUrlBtn.textContent = 'Copy';
        }, 2000);
      }
    } catch (error) {
      console.error('Copy failed:', error);
      alert('Failed to copy URL. Please copy it manually.');
    }
  }

  function openUrl() {
    if (generatedUrl) {
      window.open(generatedUrl.value, '_blank', 'noopener,noreferrer');
    }
  }

  if (markdownEditor) {
    markdownEditor.addEventListener('input', () => {
      debouncedUpdatePreview();
      saveDraft();
    });

    markdownEditor.addEventListener('keydown', (e) => {
      if (e.ctrlKey || e.metaKey) {
        if (e.key === 'b') {
          e.preventDefault();
          insertMarkdown('bold');
        } else if (e.key === 'i') {
          e.preventDefault();
          insertMarkdown('italic');
        }
      }
    });
  }

  if (themeSelector) {
    themeSelector.addEventListener('change', updatePreviewTheme);
  }

  if (generateUrlBtn) {
    generateUrlBtn.addEventListener('click', generateUrl);
  }

  if (closeModalBtn) {
    closeModalBtn.addEventListener('click', closeModal);
  }

  if (copyUrlBtn) {
    copyUrlBtn.addEventListener('click', copyUrl);
  }

  if (openUrlBtn) {
    openUrlBtn.addEventListener('click', openUrl);
  }

  if (urlModal) {
    urlModal.addEventListener('click', (e) => {
      if (e.target === urlModal) {
        closeModal();
      }
    });
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && urlModal && !urlModal.classList.contains('hidden')) {
      closeModal();
    }
  });

  formatButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const format = btn.getAttribute('data-format');
      if (format) insertMarkdown(format);
    });
  });

  // Initialize
  if (typeof window !== 'undefined') {
    updatePreviewTheme();
    restoreDraft();
  }
</script>
